{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Aurora SkinSense: Next.js",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Ready in\\s+\\S+",
        "uriFormat": "http://localhost:3000",
        "action": "openExternally"
      }
    }
  ]
}
