    "clsx": "^2.1.1",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
